# Avenue — environment template (copy to .env.production on server)
# Never commit real secrets.

NODE_ENV=production
PORT=3000

# Public site URL (used by NextAuth, emails, feeds)
NEXTAUTH_URL=https://www.example.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# MongoDB — use direct connection string if mongodb+srv fails on host
MONGODB_URI=mongodb://USER:PASSWORD@host1:27017,host2:27017,host3:27017/avenue?ssl=true&authSource=admin&retryWrites=true&w=majority

# Shared secret between avenue-admin BFF and Avenue admin APIs
# Generate: openssl rand -hex 32
ADMIN_API_TOKEN=

# Optional: Strapi CMS
STRAPI_URL=
STRAPI_TOKEN=

# Payments (if used)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Sync jobs (cron / internal)
SYNC_SECRET=

# FTP / Gardners (if used)
GARDNERS_PHYSICAL_FTP_HOST=
GARDNERS_PHYSICAL_FTP_USER=
GARDNERS_PHYSICAL_FTP_PASSWORD=
